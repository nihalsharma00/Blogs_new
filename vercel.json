{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npx prisma generate --schema=apps/api/prisma/schema.prisma && npm run build -w apps/web",
  "outputDirectory": "apps/web/dist",
  "functions": {
    "apps/api/src/vercel.ts": {
      "runtime": "@vercel/node@3",
      "includeFiles": "apps/api/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/apps/api/src/vercel.ts" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
